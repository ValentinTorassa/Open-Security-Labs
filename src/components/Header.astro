---
import { REPO_URL } from "../data/site";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/labs", label: "Aprender" },
  { href: "/rutas", label: "Rutas" },
  { href: "/certificaciones", label: "Certificaciones" },
  { href: "/portafolio", label: "Portafolio" },
  { href: "/perfil", label: "Perfil" },
  { href: "/crear-lab", label: "Crear lab" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="border-base-800 bg-base-950/80 sticky top-0 z-40 border-b backdrop-blur"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6"
  >
    <a
      href="/"
      class="group flex shrink-0 items-center gap-2.5"
      aria-label="Open Security Labs by VT Security — inicio"
    >
      <img
        src="/penguin-icon.png"
        alt=""
        width="28"
        height="28"
        class="border-base-700 group-hover:border-term-green/50 bg-base-800 h-7 w-7 rounded-md border transition-colors"
      />
      <span class="flex items-baseline gap-1.5">
        <span
          class="text-base-50 font-mono text-sm font-semibold tracking-tight"
          >Open Security</span
        >
        <span class="text-base-400 hidden font-mono text-sm sm:inline"
          >Labs</span
        >
      </span>
    </a>

    <div class="flex min-w-0 items-center gap-2">
      <!-- Nav Desktop -->
      <nav class="hidden items-center gap-2 lg:flex" aria-label="Principal">
        {
          links.map((l) => (
            <a
              href={l.href}
              class:list={[
                "shrink-0 rounded-md px-3 py-1.5 font-mono text-sm transition-colors",
                isActive(l.href)
                  ? "text-term-green"
                  : "text-base-300 hover:text-base-50",
              ]}
              aria-current={isActive(l.href) ? "page" : undefined}
            >
              {l.label}
            </a>
          ))
        }
      </nav>

      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver el repositorio en GitHub"
        class="border-base-700 hover:border-term-green/50 hidden h-9 w-9 shrink-0 items-center justify-center rounded-lg border transition-colors sm:flex"
      >
        <img
          src="/github-mark.png"
          alt=""
          width="16"
          height="16"
          class="gh-mark h-4 w-4"
          aria-hidden="true"
        />
      </a>

      <button
        type="button"
        data-cmdk-open
        aria-label="Buscar (Ctrl K)"
        class="border-base-700 text-base-400 hover:border-term-green/50 hover:text-base-100 flex h-9 w-9 shrink-0 items-center justify-center gap-2 rounded-lg border font-mono text-sm transition-colors sm:w-auto sm:px-2.5"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
          ></path></svg
        >
        <kbd class="hidden text-[0.65rem] sm:inline" data-kbd-shortcut
          >Ctrl K</kbd
        >
      </button>

      <button
        type="button"
        data-theme-toggle
        aria-label="Cambiar tema claro/oscuro"
        aria-pressed="false"
        class="theme-toggle border-base-700 text-base-400 hover:border-term-green/50 hover:text-base-100 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border transition-colors"
      >
        <svg
          class="i-sun h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"
          ></path>
        </svg>
        <svg
          class="i-moon h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>

      <button
        type="button"
        data-mobile-menu-open
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="border-base-700 text-base-400 hover:border-term-green/50 hover:text-base-100 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border transition-colors lg:hidden"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="4" x2="20" y1="12" y2="12"></line><line
            x1="4"
            x2="20"
            y1="6"
            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  data-mobile-menu
  class="bg-base-950/95 fixed inset-0 z-[100] flex hidden flex-col px-5 py-5 backdrop-blur-md transition-opacity lg:hidden"
  style="height: 100dvh;"
>
  <div class="flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <img
        src="/penguin-icon.png"
        alt=""
        width="28"
        height="28"
        class="border-base-700 bg-base-800 h-7 w-7 rounded-md border"
      />
      <span class="text-base-50 font-mono text-sm font-semibold tracking-tight"
        >Open Security</span
      >
    </a>
    <button
      type="button"
      data-mobile-menu-close
      aria-label="Cerrar menú"
      class="border-base-700 text-base-400 hover:text-base-100 rounded-md border p-1.5"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  <nav class="mt-10 flex flex-col gap-6">
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "font-mono text-lg transition-colors",
            isActive(l.href)
              ? "text-term-green font-bold"
              : "text-base-200 hover:text-base-50 font-medium",
          ]}
        >
          {l.label}
        </a>
      ))
    }
  </nav>
  <div class="border-base-800 mt-auto border-t pt-6 pb-4">
    <a
      href={REPO_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-base-400 hover:text-term-green font-mono text-sm transition-colors"
    >
      Repositorio en GitHub ↗
    </a>
    <p class="text-base-500 mt-4 font-mono text-xs">
      Open Security Labs by VT Security &copy; {new Date().getFullYear()}
    </p>
  </div>
</div>

<style>
  /* La marca de GitHub es un PNG negro sobre transparente: en tema oscuro
     se invierte para quedar blanca; en claro se muestra tal cual. */
  .gh-mark {
    filter: invert(1);
    opacity: 0.72;
    transition: opacity 0.15s;
  }
  a:hover > .gh-mark {
    opacity: 1;
  }
  :global([data-theme="light"]) .gh-mark {
    filter: none;
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const syncThemeButton = () => {
    btn?.setAttribute(
      "aria-pressed",
      String(document.documentElement.dataset.theme === "light"),
    );
  };
  syncThemeButton();
  btn?.addEventListener("click", () => {
    const light = document.documentElement.dataset.theme === "light";
    if (light) {
      delete document.documentElement.dataset.theme;
      try {
        localStorage.setItem("vtsl:theme", "dark");
      } catch {}
    } else {
      document.documentElement.dataset.theme = "light";
      try {
        localStorage.setItem("vtsl:theme", "light");
      } catch {}
    }
    syncThemeButton();
    // BaseLayout escucha esto para actualizar <meta name="theme-color">.
    window.dispatchEvent(new CustomEvent("vtsl:theme-change"));
  });

  // Mobile menu logic
  const mobileMenu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const openBtn = document.querySelector<HTMLButtonElement>(
    "[data-mobile-menu-open]",
  );
  const closeBtn = document.querySelector<HTMLButtonElement>(
    "[data-mobile-menu-close]",
  );

  const setMobileMenu = (open: boolean) => {
    mobileMenu?.classList.toggle("hidden", !open);
    document.body.style.overflow = open ? "hidden" : "";
    openBtn?.setAttribute("aria-expanded", String(open));
  };

  openBtn?.addEventListener("click", () => {
    setMobileMenu(true);
  });

  closeBtn?.addEventListener("click", () => {
    setMobileMenu(false);
    openBtn?.focus();
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMobileMenu(false));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || mobileMenu?.classList.contains("hidden")) {
      return;
    }
    setMobileMenu(false);
    openBtn?.focus();
  });

  // Trap de foco: con el menú abierto (fondo con scroll bloqueado), Tab
  // circula dentro del menú en vez de escaparse a la página tapada.
  document.addEventListener("keydown", (event) => {
    if (
      event.key !== "Tab" ||
      !mobileMenu ||
      mobileMenu.classList.contains("hidden")
    ) {
      return;
    }
    const focusables = mobileMenu.querySelectorAll<HTMLElement>(
      "a[href], button:not([disabled])",
    );
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement;
    if (!mobileMenu.contains(active)) {
      event.preventDefault();
      first.focus();
    } else if (event.shiftKey && active === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && active === last) {
      event.preventDefault();
      first.focus();
    }
  });
</script>
