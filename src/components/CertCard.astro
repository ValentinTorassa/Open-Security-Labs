---
import type { Certification } from "../data/certifications";
import CredentialBadge from "./CredentialBadge.astro";
import Icon from "./Icon.astro";

interface Props {
  cert: Certification;
}
const { cert } = Astro.props;

const stats = [
  { icon: "list-checks" as const, label: `${cert.meta.questions} preguntas` },
  { icon: "clock" as const, label: `${cert.meta.durationMin} min` },
  { icon: "gauge" as const, label: cert.meta.passingScore },
];
---

<a
  href={`/certificaciones/${cert.slug}`}
  class="card group relative flex flex-col overflow-hidden p-5 hover:-translate-y-0.5"
  style={`--accent: ${cert.accent}`}
>
  <span
    class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-70"
    style="background: linear-gradient(to right, transparent, var(--accent), transparent)"
    aria-hidden="true"></span>

  <div class="flex items-center gap-3.5">
    <CredentialBadge icon={cert.icon} accent={cert.accent} size={52} />
    <div class="min-w-0">
      <p class="truncate font-mono text-xs" style="color: var(--accent)">
        {cert.code} · {cert.level}
      </p>
      <p class="text-base-500 mt-0.5 font-mono text-[0.7rem]">{cert.vendor}</p>
    </div>
  </div>

  <h3
    class="text-base-50 mt-4 text-base leading-snug font-semibold group-hover:text-[color:var(--accent)]"
  >
    {cert.name}
  </h3>

  <p class="text-base-300 mt-2 line-clamp-2 flex-1 text-sm leading-relaxed">
    {cert.summary}
  </p>

  <div
    class="text-base-400 mt-4 grid grid-cols-3 gap-2 font-mono text-[0.7rem]"
  >
    {
      stats.map((s) => (
        <span class="border-base-800 bg-base-900/40 flex items-center gap-1.5 rounded-md border px-2 py-1.5">
          <Icon name={s.icon} size={13} class="shrink-0 opacity-70" />
          <span class="truncate">{s.label}</span>
        </span>
      ))
    }
  </div>

  <div
    class="border-base-800 text-base-400 mt-4 flex items-center gap-2 border-t pt-3 font-mono text-xs"
  >
    <span>{cert.exam.length} de práctica acá</span>
    <span
      class="ml-auto transition-transform group-hover:translate-x-0.5"
      style="color: var(--accent)"
      aria-hidden="true">→</span
    >
  </div>
</a>
