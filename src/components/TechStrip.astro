---
// Tira de logos de tecnologías que se tocan en los labs.
// Logos reales vía simple-icons (monocromos, color de marca al hover).
import {
  siLinux,
  siGnubash,
  siDocker,
  siKubernetes,
  siNginx,
  siTerraform,
  siGithubactions,
  siGithub,
  siPython,
  siWireshark,
  siCloudflare,
} from "simple-icons";

const techs = [
  siLinux,
  siGnubash,
  siDocker,
  siKubernetes,
  siNginx,
  siTerraform,
  siGithubactions,
  siGithub,
  siPython,
  siWireshark,
  siCloudflare,
];
---

<div class="flex flex-wrap items-center gap-x-7 gap-y-5">
  {
    techs.map((t) => (
      <span
        class="group inline-flex items-center"
        style={`--c:#${t.hex}`}
        title={t.title}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="26"
          height="26"
          fill="currentColor"
          role="img"
          aria-label={t.title}
          class="text-base-500 transition-colors duration-200 group-hover:text-[color:var(--c)]"
          set:html={`<path d="${t.path}"/>`}
        />
      </span>
    ))
  }
</div>
