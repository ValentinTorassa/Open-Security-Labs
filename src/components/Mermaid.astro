---
// Diagrama Mermaid renderizado en el cliente, con el tema de Open Security Labs.
// Solo se carga el JS de mermaid en las páginas que usan este componente.
interface Props {
  code: string;
  caption?: string;
}
const { code, caption } = Astro.props;
---

<figure class="not-prose my-7">
  <div
    class="border-base-700 bg-base-900 overflow-x-auto rounded-xl border p-4 sm:p-6"
  >
    <pre class="mermaid flex justify-center text-center">{code}</pre>
  </div>
  {
    caption && (
      <figcaption class="text-base-400 mt-2 text-center font-mono text-xs">
        {caption}
      </figcaption>
    )
  }
</figure>

<script>
  // Carga diferida: el bundle de mermaid pesa ~600 KB, así que recién se
  // baja cuando un diagrama se acerca al viewport.
  const targets = document.querySelectorAll<HTMLElement>(".mermaid");

  let started = false;
  const start = async () => {
    if (started) return;
    started = true;
    const { default: mermaid } = await import("mermaid");
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "strict",
      theme: "base",
      fontFamily: "JetBrains Mono Variable, ui-monospace, monospace",
      themeVariables: {
        darkMode: true,
        background: "#07090a",
        mainBkg: "#101518",
        primaryColor: "#101518",
        primaryTextColor: "#dde4e8",
        primaryBorderColor: "#273139",
        secondaryColor: "#07090a",
        tertiaryColor: "#07090a",
        lineColor: "#4ade80",
        textColor: "#b9c4cb",
        nodeBorder: "#273139",
        clusterBkg: "#07090a",
        clusterBorder: "#1a2228",
        edgeLabelBackground: "#07090a",
        fontSize: "14px",
      },
    });
    await mermaid.run({ querySelector: ".mermaid" });
  };

  if (targets.length > 0) {
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            io.disconnect();
            void start();
          }
        },
        { rootMargin: "400px 0px" },
      );
      targets.forEach((t) => io.observe(t));
    } else {
      void start();
    }
  }
</script>
