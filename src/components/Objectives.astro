---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="border-base-700 bg-base-850/60 my-6 rounded-lg border p-4">
      <h3 class="rule-label mb-3">Al terminar vas a poder</h3>
      <ul class="grid gap-2 sm:grid-cols-2">
        {items.map((item) => (
          <li class="text-base-200 flex gap-2.5 text-sm">
            <span class="text-term-green mt-0.5 font-mono" aria-hidden="true">
              ✓
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>
  )
}
