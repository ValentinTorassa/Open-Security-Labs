---
// Emblema hexagonal tipo credencial para las certificaciones.
// Reemplaza el cuadradito de iniciales por un escudo con el ícono del vendor.
import Icon from "./Icon.astro";
import type { IconName } from "../data/icons";

interface Props {
  icon: IconName;
  accent: string;
  size?: number;
  class?: string;
}

const { icon, accent, size = 56, class: className = "" } = Astro.props;
const uid = `cb-${Math.random().toString(36).slice(2, 9)}`;
const iconSize = Math.round(size * 0.4);
---

<span
  class:list={[
    "relative inline-flex shrink-0 items-center justify-center",
    className,
  ]}
  style={`width:${size}px;height:${size}px`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 100 100"
    width={size}
    height={size}
    class="absolute inset-0"
  >
    <defs>
      <linearGradient id={uid} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color={accent} stop-opacity="0.24"></stop>
        <stop offset="100%" stop-color={accent} stop-opacity="0.04"></stop>
      </linearGradient>
    </defs>
    <polygon
      points="50,3 91,26.5 91,73.5 50,97 9,73.5 9,26.5"
      fill={`url(#${uid})`}
      stroke={accent}
      stroke-opacity="0.6"
      stroke-width="2.5"
      stroke-linejoin="round"></polygon>
    <polygon
      points="50,14 81,32 81,68 50,86 19,68 19,32"
      fill="none"
      stroke={accent}
      stroke-opacity="0.18"
      stroke-width="1.5"
      stroke-linejoin="round"></polygon>
  </svg>
  <span class="relative" style={`color:${accent}`}>
    <Icon name={icon} size={iconSize} strokeWidth={1.75} />
  </span>
</span>
