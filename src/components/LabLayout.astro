---
import type { CollectionEntry } from "astro:content";
import { getPath } from "../data/paths";
import Prerequisites from "./Prerequisites.astro";
import Objectives from "./Objectives.astro";
import EvidenceBox from "./EvidenceBox.astro";
import ChallengeBox from "./ChallengeBox.astro";
import NextLabLinks from "./NextLabLinks.astro";
import LabLevel from "./LabLevel.astro";

interface Props {
  lab: CollectionEntry<"labs">;
}
const { lab } = Astro.props;
const { data } = lab;
const path = getPath(data.path);
const accent = path?.accent ?? "#56d364";
---

<article class="py-10" style={`--accent: ${accent}`}>
  <!-- Breadcrumb -->
  <nav class="text-base-400 mb-6 font-mono text-xs" aria-label="Migas de pan">
    <a href="/labs" class="hover:text-term-green">labs</a>
    <span class="text-base-600 mx-1.5">/</span>
    {
      path && (
        <a
          href={`/rutas/${path.slug}`}
          class="hover:text-[color:var(--accent)]"
          style="color: var(--accent)"
        >
          {path.slug}
        </a>
      )
    }
  </nav>

  <!-- Header -->
  <header class="border-base-800 mb-8 border-b pb-8">
    <div class="flex flex-wrap items-center gap-2 font-mono text-xs">
      <span
        class="rounded border px-2 py-0.5"
        style="border-color: color-mix(in srgb, var(--accent) 35%, transparent); color: var(--accent)"
      >
        {path?.title ?? data.path}
      </span>
      <span class="border-base-700 text-base-400 rounded border px-2 py-0.5">
        <LabLevel level={data.level} />
      </span>
      <span class="text-base-400">· {data.estimatedMinutes} min</span>
    </div>

    <h1 class="text-base-50 mt-4 text-3xl leading-tight font-bold sm:text-4xl">
      {data.title}
    </h1>
    <p class="text-base-300 mt-3 text-lg leading-relaxed">{data.description}</p>

    {
      data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {data.tags.map((t) => (
            <span class="text-base-500 font-mono text-xs">#{t}</span>
          ))}
        </div>
      )
    }
  </header>

  <Prerequisites items={data.prerequisites} />
  <Objectives items={data.objectives} />

  <!-- Cuerpo del lab (MDX) -->
  <div class="lab-prose prose prose-invert mt-8 max-w-none">
    <slot />
  </div>

  {data.evidence.length > 0 && <EvidenceBox items={data.evidence} />}
  {data.challenge && <ChallengeBox prompt={data.challenge} flag={data.flag} />}
  {data.nextLabs.length > 0 && <NextLabLinks ids={data.nextLabs} />}

  <!-- Pie del lab -->
  <footer
    class="border-base-700 bg-base-850/50 text-base-300 mt-12 rounded-xl border p-5 text-sm"
  >
    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="text-base-400 font-mono text-xs">¿Hiciste el lab?</p>
      <button
        type="button"
        data-lab-done
        data-lab-id={lab.id}
        class="btn-ghost text-xs"
        aria-pressed="false"
      >
        Marcar como hecho
      </button>
    </div>
    <p class="mt-3">
      Si querés, guardá lo que hiciste (comandos, notas, un repo) para volver
      después. Y si encontrás un error o querés mejorar este lab,
      <a href="/contribuir" class="text-term-green hover:underline"
        >contribuí al repo</a
      >. El progreso se guarda solo en tu navegador.
    </p>
  </footer>
</article>

<script>
  import { isLabDone, toggleLabDone, onProgress } from "../scripts/progress";

  document
    .querySelectorAll<HTMLButtonElement>("[data-lab-done]")
    .forEach((btn) => {
      const id = btn.dataset.labId ?? "";
      const render = () => {
        const done = isLabDone(id);
        btn.textContent = done ? "✓ Hecho · desmarcar" : "Marcar como hecho";
        btn.setAttribute("aria-pressed", String(done));
        btn.classList.toggle("border-term-green", done);
        btn.classList.toggle("text-term-green", done);
      };
      btn.addEventListener("click", () => toggleLabDone(id));
      onProgress(render);
      render();
    });

  // Copy to clipboard logic
  document.querySelectorAll(".lab-prose pre").forEach((pre) => {
    if (pre.classList.contains("mermaid")) return;

    // Find if the pre is inside a TerminalBlock wrapper
    const wrapper = pre.closest(".border-base-700.bg-base-900") || pre;
    if (wrapper.querySelector(".copy-btn")) return;

    const btn = document.createElement("button");
    btn.className =
      "copy-btn absolute right-2 rounded p-1.5 text-base-400 hover:text-base-100 transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100 z-10";

    // Position differently based on wrapper type
    if (wrapper === pre) {
      // Standard markdown code block
      btn.classList.add("top-2", "bg-base-800/80", "hover:bg-base-700");
    } else {
      // TerminalBlock (place button in the header area)
      btn.classList.add("top-1.5", "bg-base-800/80", "hover:bg-base-700");
    }

    btn.setAttribute("aria-label", "Copiar código");
    btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

    wrapper.classList.add("relative", "group");

    btn.addEventListener("click", async () => {
      const code = pre.querySelector("code") || pre;
      const text = code.textContent || "";

      try {
        await navigator.clipboard.writeText(text);
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-term-green"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        setTimeout(() => {
          btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
        }, 2000);
      } catch (err) {
        console.error("Fallo al copiar: ", err);
      }
    });

    wrapper.appendChild(btn);
  });
</script>
