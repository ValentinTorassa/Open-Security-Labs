---
import { createHash } from "node:crypto";

interface Props {
  /** Enunciado del reto. Si no se pasa, usa el slot. */
  prompt?: string;
  title?: string;
  flag?: string;
}
const { prompt, title = "Reto", flag } = Astro.props;

// La flag nunca viaja en texto plano al HTML: se embebe su SHA-256 y el
// cliente hashea lo que escribís antes de comparar. Dogfooding de
// "hashear no es cifrar", y de paso la respuesta no está a un view-source.
const flagHash = flag
  ? createHash("sha256").update(flag.trim()).digest("hex")
  : undefined;
---

<section
  class="border-term-amber/30 bg-term-amber/5 my-8 rounded-xl border p-5"
>
  <h3
    class="text-term-amber flex items-center gap-2 font-mono text-sm font-semibold"
  >
    <span aria-hidden="true">⚑</span>
    {title}
  </h3>
  <div class="text-base-100 mt-3 text-sm leading-relaxed">
    {prompt ? <p>{prompt}</p> : <slot />}
  </div>

  {
    flag ? (
      <>
        <form
          data-flag-form
          data-expected-hash={flagHash}
          class="mt-4 flex flex-col gap-3 sm:flex-row"
        >
          <input
            type="text"
            placeholder="Ingresá la flag..."
            class="border-base-700 bg-base-900 text-base-100 focus:border-term-amber w-full rounded-md border px-3 py-2 font-mono text-sm transition-colors outline-none"
            required
          />
          <button
            type="submit"
            class="bg-term-amber text-base-950 hover:bg-term-amber/90 shrink-0 rounded-md px-4 py-2 font-mono text-sm font-bold transition-colors"
          >
            Verificar
          </button>
        </form>
        <p
          data-flag-message
          role="status"
          class="mt-3 hidden font-mono text-xs font-semibold"
        />
      </>
    ) : (
      <p class="text-base-400 mt-4 font-mono text-xs">
        Resolvelo y escribí dos líneas explicando qué pasó. Con eso lo fijás.
      </p>
    )
  }
</section>

<script>
  const sha256Hex = async (text: string): Promise<string> => {
    const digest = await crypto.subtle.digest(
      "SHA-256",
      new TextEncoder().encode(text),
    );
    return Array.from(new Uint8Array(digest))
      .map((b) => b.toString(16).padStart(2, "0"))
      .join("");
  };

  document
    .querySelectorAll<HTMLFormElement>("[data-flag-form]")
    .forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const input = form.querySelector("input");
        const msg = form.nextElementSibling as HTMLElement;
        if (!input || !msg) return;

        const expectedHash = form.dataset.expectedHash;
        const actual = input.value.trim();

        msg.classList.remove("hidden", "text-term-green", "text-red-400");
        input.classList.remove("border-term-green", "border-red-400");

        let ok = false;
        try {
          // crypto.subtle solo existe en contextos seguros (https/localhost).
          ok = expectedHash === (await sha256Hex(actual));
        } catch {
          msg.textContent =
            "✗ No se pudo verificar acá (necesita https). Anotá tu respuesta igual.";
          msg.classList.add("text-red-400");
          return;
        }

        if (ok) {
          msg.textContent =
            "✓ ¡Flag correcta! Ya podés marcar el lab como hecho.";
          msg.classList.add("text-term-green");
          input.classList.add("border-term-green");
        } else {
          msg.textContent = "✗ Flag incorrecta. Seguí intentando.";
          msg.classList.add("text-red-400");
          input.classList.add("border-red-400");
        }
      });
    });
</script>
