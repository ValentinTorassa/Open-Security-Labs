---
// El índice de búsqueda vive en /search-index.json (src/pages/search-index.json.ts)
// y se baja con fetch() la primera vez que se abre el palette, en vez de
// viajar inline en el HTML de todas las páginas.
---

<div
  data-cmdk-root
  class="fixed inset-x-0 top-0 z-50 hidden items-start justify-center overflow-y-auto px-4 py-4 sm:py-[12vh]"
  style="height: var(--cmdk-height, 100dvh);"
  role="dialog"
  aria-modal="true"
  aria-label="Buscar en el sitio"
>
  <div
    data-cmdk-backdrop
    class="bg-base-950/70 absolute inset-0 backdrop-blur-sm"
  >
  </div>
  <div
    class="border-base-700 bg-base-900 relative w-full max-w-xl overflow-hidden rounded-xl border"
    style="max-height: calc(var(--cmdk-height, 100dvh) - 2rem);"
  >
    <div class="border-base-800 flex items-center gap-2 border-b px-4">
      <svg
        class="text-term-green h-4 w-4 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        data-cmdk-input
        type="text"
        role="combobox"
        aria-expanded="false"
        aria-controls="cmdk-list"
        aria-activedescendant=""
        autocomplete="off"
        spellcheck="false"
        placeholder="Buscar labs, rutas, herramientas…"
        aria-label="Buscar"
        class="text-base-100 placeholder:text-base-500 w-full bg-transparent py-3.5 font-mono text-sm outline-none"
      />
      <kbd
        class="border-base-700 text-base-500 hidden rounded border px-1.5 py-0.5 font-mono text-[0.65rem] sm:inline"
        >esc</kbd
      >
    </div>
    <ul
      id="cmdk-list"
      data-cmdk-list
      class="overflow-y-auto p-2"
      style="max-height: min(400px, calc(var(--cmdk-height, 100dvh) - 11rem));"
      role="listbox"
    >
    </ul>
    <p
      data-cmdk-empty
      class="text-base-500 hidden px-4 py-6 text-center font-mono text-sm"
    >
      Sin resultados.
    </p>
    <div
      class="border-base-800 text-base-500 hidden items-center gap-3 border-t px-4 py-2 font-mono text-[0.65rem] sm:flex"
    >
      <span><kbd class="text-base-300">↑↓</kbd> navegar</span>
      <span><kbd class="text-base-300">↵</kbd> abrir</span>
      <span class="ml-auto"
        ><kbd class="text-base-300" data-kbd-shortcut>Ctrl K</kbd></span
      >
    </div>
  </div>
</div>

<script>
  type Item = {
    href: string;
    title: string;
    sub: string;
    kind: string;
    keywords: string;
  };

  // Etiqueta del atajo según el sistema: ⌘ en Mac, Ctrl en Linux/Windows.
  const isMac = /macintosh|mac os x|iphone|ipad|ipod/i.test(
    navigator.userAgent,
  );
  const modLabel = isMac ? "⌘K" : "Ctrl K";
  document.querySelectorAll("[data-kbd-shortcut]").forEach((el) => {
    el.textContent = modLabel;
  });
  document
    .querySelector("[data-cmdk-open]")
    ?.setAttribute("aria-label", `Buscar (${modLabel})`);

  const root = document.querySelector<HTMLElement>("[data-cmdk-root]");
  const input = document.querySelector<HTMLInputElement>("[data-cmdk-input]");
  const list = document.querySelector<HTMLElement>("[data-cmdk-list]");
  const empty = document.querySelector<HTMLElement>("[data-cmdk-empty]");

  if (root && input && list && empty) {
    const listEl = list;
    const emptyEl = empty;
    let items: Item[] = [];
    let indexPromise: Promise<void> | null = null;
    const ensureIndex = () => {
      indexPromise ??= fetch("/search-index.json")
        .then((r) => (r.ok ? r.json() : []))
        .then((data: Item[]) => {
          items = data;
        })
        .catch(() => {
          // Permite reintentar en la próxima apertura si falló la red.
          indexPromise = null;
        });
      return indexPromise;
    };
    let active = 0;
    let results: Item[] = [];
    let lastTrigger: HTMLElement | null = null;
    const isOpen = () => !root.classList.contains("hidden");

    const syncViewport = () => {
      const height = window.visualViewport?.height ?? window.innerHeight;
      root.style.setProperty("--cmdk-height", `${height}px`);
    };

    const onViewportResize = () => {
      if (!isOpen()) return;
      syncViewport();
    };

    window.visualViewport?.addEventListener("resize", onViewportResize);
    window.addEventListener("resize", onViewportResize);

    const open = () => {
      syncViewport();
      root.classList.remove("hidden");
      root.classList.add("flex");
      input.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      input.value = "";
      render("");
      void ensureIndex().then(() => {
        if (isOpen()) render(input.value);
      });
      requestAnimationFrame(() => input.focus({ preventScroll: true }));
    };
    const close = () => {
      root.classList.add("hidden");
      root.classList.remove("flex");
      input.setAttribute("aria-expanded", "false");
      input.setAttribute("aria-activedescendant", "");
      document.body.style.overflow = "";
      lastTrigger?.focus();
    };

    function score(it: Item, q: string): number {
      if (!q) return 1;
      const hay = (it.title + " " + it.keywords).toLowerCase();
      if (hay.includes(q)) return 2;
      // subsecuencia: cada caracter de q aparece en orden
      let i = 0;
      for (const ch of hay) if (ch === q[i]) i += 1;
      return i === q.length ? 1 : 0;
    }

    function render(q: string) {
      const query = q.trim().toLowerCase();
      results = items
        .map((it) => ({ it, s: score(it, query) }))
        .filter((r) => r.s > 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 12)
        .map((r) => r.it);
      active = 0;
      listEl.innerHTML = "";
      emptyEl.classList.toggle("hidden", results.length > 0);
      results.forEach((it, idx) => {
        const li = document.createElement("li");
        li.id = `cmdk-option-${idx}`;
        li.setAttribute("role", "option");
        li.setAttribute("aria-selected", "false");
        li.dataset.idx = String(idx);
        li.className =
          "flex cursor-pointer items-center gap-3 rounded-lg px-3 py-2.5";
        // textContent (no innerHTML): title/sub vienen del frontmatter de labs
        // aportados por PR, no pueden inyectar HTML.
        const kindEl = document.createElement("span");
        kindEl.className =
          "shrink-0 rounded border border-base-700 bg-base-800/60 px-1.5 py-0.5 font-mono text-[0.6rem] text-base-400";
        kindEl.textContent = it.kind;
        const bodyEl = document.createElement("span");
        bodyEl.className = "min-w-0 flex-1";
        const titleEl = document.createElement("span");
        titleEl.className = "block truncate text-sm text-base-100";
        titleEl.textContent = it.title;
        const subEl = document.createElement("span");
        subEl.className =
          "block truncate font-mono text-[0.7rem] text-base-500";
        subEl.textContent = it.sub;
        bodyEl.append(titleEl, subEl);
        li.append(kindEl, bodyEl);
        li.addEventListener("click", () => go(idx));
        li.addEventListener("mousemove", () => {
          active = idx;
          paint();
        });
        listEl.appendChild(li);
      });
      paint();
    }

    function paint() {
      Array.from(listEl.children).forEach((el, idx) => {
        el.classList.toggle("bg-base-800", idx === active);
        el.setAttribute("aria-selected", String(idx === active));
        if (idx === active) el.scrollIntoView({ block: "nearest" });
      });
      const activeEl = listEl.children[active] as HTMLElement | undefined;
      input?.setAttribute("aria-activedescendant", activeEl?.id ?? "");
    }

    function go(idx: number) {
      const it = results[idx];
      if (it) window.location.href = it.href;
    }

    input.addEventListener("input", () => render(input.value));

    document.addEventListener("keydown", (e) => {
      const k = e.key.toLowerCase();
      const mod = e.metaKey || e.ctrlKey;
      if (mod && k === "k") {
        e.preventDefault();
        if (isOpen()) {
          close();
        } else {
          lastTrigger = document.activeElement as HTMLElement | null;
          open();
        }
        return;
      }
      if (!isOpen()) return;
      if (k === "escape") {
        e.preventDefault();
        close();
      } else if (k === "arrowdown") {
        e.preventDefault();
        active = Math.min(active + 1, results.length - 1);
        paint();
      } else if (k === "arrowup") {
        e.preventDefault();
        active = Math.max(active - 1, 0);
        paint();
      } else if (k === "enter") {
        e.preventDefault();
        go(active);
      } else if (k === "tab") {
        // Trap de foco: el diálogo es modal, el input es el único foco útil.
        e.preventDefault();
        input.focus();
      }
    });

    root
      .querySelector("[data-cmdk-backdrop]")
      ?.addEventListener("click", close);

    // Cualquier elemento [data-cmdk-open] abre el buscador.
    document.querySelectorAll("[data-cmdk-open]").forEach((el) =>
      el.addEventListener("click", (e) => {
        e.preventDefault();
        lastTrigger = el as HTMLElement;
        open();
      }),
    );
  }
</script>
