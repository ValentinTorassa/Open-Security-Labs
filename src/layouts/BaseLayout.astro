---
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
// Subset latino (cubre acentos/ñ del español) de cada variable font: precargado
// para evitar FOUT/FOIT en el primer paint, sin bajar el resto de los subsets.
import interLatinWoff2 from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import jetbrainsMonoLatinWoff2 from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CommandPalette from "../components/CommandPalette.astro";
import { SITE_URL } from "../data/site";

interface Props {
  title: string;
  description?: string;
  /** Ancho del contenido principal. `wide` para landing, `prose` para labs. */
  width?: "default" | "wide" | "prose";
  /** Imagen para compartir en redes (relativa al sitio). */
  image?: string;
  /** Tipo Open Graph: `article` para contenido tipo lab. */
  ogType?: "website" | "article";
  /** Structured data adicional (p. ej. TechArticle de un lab). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Labs prácticos en español para entender Linux, redes, backend, cloud y ciberseguridad de verdad. Aprendé construyendo evidencia.",
  width = "default",
  image = "/og-default.png",
  ogType = "website",
  jsonLd: extraJsonLd,
} = Astro.props;

const fullTitle =
  title === "Open Security Labs" ? title : `${title} · Open Security Labs`;

const mainWidth =
  width === "wide"
    ? "max-w-6xl"
    : width === "prose"
      ? "max-w-3xl"
      : "max-w-5xl";

// URLs absolutas para SEO y tarjetas sociales.
const site = Astro.site ?? new URL(SITE_URL);
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(image, site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Open Security Labs",
  url: site.href,
  description,
  inLanguage: "es-AR",
  author: {
    "@type": "Person",
    name: "Valentín Torassa Colombero",
    url: "https://valentorassa.com",
  },
};

const extraJsonLdItems = Array.isArray(extraJsonLd)
  ? extraJsonLd
  : extraJsonLd
    ? [extraJsonLd]
    : [];
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={interLatinWoff2}
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={jetbrainsMonoLatinWoff2}
      crossorigin
    />

    <script is:inline>
      // Tema antes del primer paint para evitar flash. Default: oscuro.
      (() => {
        try {
          const t = localStorage.getItem("vtsl:theme");
          if (t === "light") document.documentElement.dataset.theme = "light";
        } catch {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/penguin-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07090a" />
    <script is:inline>
      // Sincroniza theme-color con el tema activo (el toggle emite vtsl:theme-change).
      (() => {
        const meta = document.querySelector('meta[name="theme-color"]');
        const sync = () => {
          if (!meta) return;
          meta.setAttribute(
            "content",
            document.documentElement.dataset.theme === "light"
              ? "#ffffff"
              : "#07090a",
          );
        };
        sync();
        window.addEventListener("vtsl:theme-change", sync);
      })();
    </script>
    <link rel="canonical" href={canonical.href} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Open Security Labs"
      href={new URL("/rss.xml", site).href}
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Open Security Labs" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <meta name="twitter:image:alt" content={description} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
    {
      extraJsonLdItems.map((item) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(item)}
        />
      ))
    }
  </head>
  <body class="bg-base-950 min-h-screen antialiased">
    <a
      href="#contenido"
      class="bg-term-green text-base-950 sr-only rounded px-3 py-2 font-mono text-sm focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      Saltar al contenido
    </a>

    <Header />

    <main
      id="contenido"
      class:list={["mx-auto w-full px-5 sm:px-6", mainWidth]}
    >
      <slot />
    </main>

    <Footer />
    <CommandPalette />
  </body>
</html>
