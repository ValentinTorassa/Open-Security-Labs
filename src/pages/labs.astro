---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LabCard from "../components/LabCard.astro";
import LabLevel from "../components/LabLevel.astro";
import { paths } from "../data/paths";
import { sortLabs } from "../data/labs";
import { SITE_URL } from "../data/site";

const labs = await getCollection("labs", ({ data }) => !data.draft);
const sorted = sortLabs(labs);

const totalMin = labs.reduce((acc, l) => acc + l.data.estimatedMinutes, 0);
const totalPractice =
  totalMin >= 60
    ? `~${Math.round(totalMin / 60)} h de práctica`
    : `~${totalMin} min de práctica`;

const levels = [
  { value: "beginner" as const },
  { value: "intermediate" as const },
  { value: "advanced" as const },
];

const chip =
  "shrink-0 rounded-full border px-3 py-1 font-mono text-xs transition-colors";
const chipOff = "border-base-700 text-base-400 hover:text-base-100";

const site = Astro.site ?? new URL(SITE_URL);
const labsJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Todos los labs",
  url: new URL("/labs/", site).href,
  inLanguage: "es-AR",
  numberOfItems: labs.length,
  about: paths.map((path) => path.title),
};
---

<BaseLayout
  title="Todos los labs"
  description="Catálogo completo de labs prácticos de Open Security Labs. Comandos reales, criterio técnico y aprendizaje libre."
  width="wide"
  jsonLd={labsJsonLd}
>
  <section class="py-12">
    <p class="rule-label">Catálogo</p>
    <h1 class="text-base-50 mt-3 text-3xl font-bold sm:text-4xl">
      Todos los labs
    </h1>
    <p class="text-base-300 mt-4 max-w-2xl text-lg leading-relaxed">
      Cada lab es autocontenido: lo corrés en local, completás el reto y lo
      practicás en tu propia máquina. Aprendizaje libre y open source.
    </p>

    <div class="text-base-400 mt-6 flex flex-wrap gap-4 font-mono text-xs">
      <span><span class="text-term-green">{labs.length}</span> labs</span>
      <span><span class="text-term-green">{paths.length}</span> rutas</span>
      <span
        ><span class="text-term-green">{totalPractice.split(" ")[0]}</span>
        {totalPractice.split(" ").slice(1).join(" ")}</span
      >
      <span data-progress class="hidden"
        ><span class="text-term-green" data-progress-count>0</span> completados</span
      >
    </div>

    <!-- Banner "seguí con": próximo lab pendiente según tu progreso. -->
    <a
      data-resume
      href="#"
      class="card mt-8 hidden items-center gap-4 p-4 hover:-translate-y-0.5"
    >
      <span
        class="bg-term-green/10 text-term-green grid h-10 w-10 shrink-0 place-items-center rounded-full font-mono"
        aria-hidden="true">→</span
      >
      <span class="min-w-0 flex-1">
        <span class="text-base-400 block font-mono text-xs">Seguí con</span>
        <span
          class="text-base-50 block truncate text-sm font-semibold"
          data-resume-title></span>
      </span>
      <span
        class="text-term-green shrink-0 font-mono text-sm"
        aria-hidden="true">abrir →</span
      >
    </a>

    <!-- Búsqueda -->
    <div class="mt-8">
      <label for="lab-search" class="sr-only">Buscar labs</label>
      <div class="relative max-w-md">
        <svg
          class="text-base-500 pointer-events-none absolute top-1/2 left-3 h-4 w-4 -translate-y-1/2"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="lab-search"
          type="search"
          inputmode="search"
          placeholder="buscar por título, ruta o tag…"
          data-lab-search
          class="border-base-700 bg-base-850/60 text-base-100 placeholder:text-base-500 focus:border-term-green w-full rounded-lg border py-2.5 pr-3 pl-8 font-mono text-sm outline-none"
        />
      </div>
    </div>

    <!-- Filtros -->
    <div class="mt-5 space-y-3">
      <div class="flex flex-wrap items-center gap-2" data-filter-group="path">
        <span class="text-base-500 mr-1 font-mono text-[0.7rem]">Ruta:</span>
        <button
          class:list={[chip, chipOff]}
          data-filter="path"
          data-value=""
          aria-pressed="true"
        >
          Todas
        </button>
        {
          paths.map((p) => (
            <button
              class:list={[chip, chipOff]}
              data-filter="path"
              data-value={p.slug}
              aria-pressed="false"
            >
              {p.short}
            </button>
          ))
        }
      </div>
      <div class="flex flex-wrap items-center gap-2" data-filter-group="level">
        <span class="text-base-500 mr-1 font-mono text-[0.7rem]">Nivel:</span>
        <button
          class:list={[chip, chipOff]}
          data-filter="level"
          data-value=""
          aria-pressed="true"
        >
          Todos
        </button>
        {
          levels.map((l) => (
            <button
              class:list={[chip, chipOff]}
              data-filter="level"
              data-value={l.value}
              aria-pressed="false"
            >
              <LabLevel level={l.value} />
            </button>
          ))
        }
      </div>
      <div class="flex flex-wrap items-center gap-2" data-filter-group="state">
        <span class="text-base-500 mr-1 font-mono text-[0.7rem]">Estado:</span>
        <button
          class:list={[chip, chipOff]}
          data-filter="state"
          data-value=""
          aria-pressed="true"
        >
          Todos
        </button>
        <button
          class:list={[chip, chipOff]}
          data-filter="state"
          data-value="pending"
          aria-pressed="false"
        >
          Pendientes
        </button>
        <button
          class:list={[chip, chipOff]}
          data-filter="state"
          data-value="done"
          aria-pressed="false"
        >
          Hechos
        </button>
      </div>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-lab-grid>
      {sorted.map((lab) => <LabCard lab={lab} />)}
    </div>

    <div
      class="text-base-400 mt-10 hidden text-center font-mono text-sm"
      data-no-results
    >
      <p>No hay labs que coincidan con tu búsqueda.</p>
      <button type="button" class="btn-ghost mt-3 text-xs" data-clear-filters>
        Limpiar búsqueda y filtros
      </button>
    </div>
  </section>
</BaseLayout>

<script>
  import { isLabDone, onProgress } from "../scripts/progress";

  const cards = Array.from(
    document.querySelectorAll<HTMLElement>("[data-lab-card]"),
  );

  const progress = document.querySelector<HTMLElement>("[data-progress]");
  const progressCount = document.querySelector<HTMLElement>(
    "[data-progress-count]",
  );
  const resume = document.querySelector<HTMLAnchorElement>("[data-resume]");
  const resumeTitle = document.querySelector<HTMLElement>(
    "[data-resume-title]",
  );
  const input = document.querySelector<HTMLInputElement>("[data-lab-search]");
  const noResults = document.querySelector<HTMLElement>("[data-no-results]");
  const clearFilters = document.querySelector<HTMLButtonElement>(
    "[data-clear-filters]",
  );
  const chips = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-filter]"),
  );

  const ON = ["border-term-green", "text-term-green"];
  const OFF = ["border-base-700", "text-base-400"];

  const filters = { path: "", level: "", state: "" };

  function setChipStyles() {
    chips.forEach((c) => {
      const dim = c.dataset.filter as keyof typeof filters;
      const on = filters[dim] === (c.dataset.value ?? "");
      c.classList.toggle(ON[0], on);
      c.classList.toggle(ON[1], on);
      c.classList.toggle(OFF[0], !on);
      c.classList.toggle(OFF[1], !on);
      c.setAttribute("aria-pressed", String(on));
    });
  }

  function apply() {
    const q = (input?.value ?? "").trim().toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const id = card.dataset.labId ?? "";
      const done = isLabDone(id);
      const haystack = [
        card.dataset.title ?? "",
        card.dataset.description ?? "",
        card.dataset.path ?? "",
        card.dataset.level ?? "",
        card.dataset.levelLabel ?? "",
        card.dataset.tags ?? "",
        card.dataset.contributor ?? "",
      ].join(" ");

      const matchQ = q === "" || haystack.includes(q);
      const matchPath = !filters.path || card.dataset.path === filters.path;
      const matchLevel = !filters.level || card.dataset.level === filters.level;
      const matchState =
        !filters.state || (filters.state === "done" ? done : !done);

      const show = matchQ && matchPath && matchLevel && matchState;
      card.classList.toggle("hidden", !show);
      if (show) visible += 1;
    });
    noResults?.classList.toggle("hidden", visible !== 0);
  }

  clearFilters?.addEventListener("click", () => {
    if (input) input.value = "";
    filters.path = "";
    filters.level = "";
    filters.state = "";
    setChipStyles();
    apply();
  });

  function renderProgress() {
    let done = 0;
    let next: HTMLElement | null = null;
    cards.forEach((card) => {
      const id = card.dataset.labId ?? "";
      const ok = isLabDone(id);
      if (ok) done += 1;
      else if (!next) next = card;
      const badge = card.querySelector("[data-done-badge]");
      badge?.classList.toggle("hidden", !ok);
      badge?.classList.toggle("inline-flex", ok);
    });

    if (progress && progressCount) {
      progressCount.textContent = String(done);
      progress.classList.toggle("hidden", done === 0);
    }

    // Banner "seguí con" solo si ya empezó y queda algo pendiente.
    if (resume && resumeTitle) {
      if (done > 0 && next) {
        const el = next as HTMLElement;
        const title =
          el.querySelector("h3")?.textContent?.trim() ?? "Próximo lab";
        resume.href = (el as HTMLAnchorElement).href;
        resumeTitle.textContent = title;
        resume.classList.remove("hidden");
        resume.classList.add("flex");
      } else {
        resume.classList.add("hidden");
        resume.classList.remove("flex");
      }
    }
  }

  chips.forEach((c) =>
    c.addEventListener("click", () => {
      const dim = c.dataset.filter as keyof typeof filters;
      filters[dim] = c.dataset.value ?? "";
      setChipStyles();
      apply();
    }),
  );
  input?.addEventListener("input", apply);

  setChipStyles();
  renderProgress();
  apply();
  onProgress(() => {
    renderProgress();
    apply();
  });
</script>
