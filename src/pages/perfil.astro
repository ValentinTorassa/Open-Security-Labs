---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BadgeMedal from "../components/BadgeMedal.astro";
import { paths } from "../data/paths";
import { badges } from "../data/badges";
import { sortLabs } from "../data/labs";

const labs = sortLabs(await getCollection("labs", ({ data }) => !data.draft));
const sortedLabs = labs;
const firstLab =
  sortedLabs.find((l) => l.data.level === "beginner") ?? sortedLabs[0];
const firstLabHref = firstLab ? `/labs/${firstLab.id}` : "/labs";

const avatarOptions = [
  { id: "penguin", emoji: "🐧", label: "Pingüino", accent: "#56d364" },
  { id: "shield", emoji: "🛡️", label: "Defensa", accent: "#58a6ff" },
  { id: "brain", emoji: "🧠", label: "Criterio", accent: "#bc8cff" },
  { id: "bolt", emoji: "⚡", label: "Energía", accent: "#e3b341" },
  { id: "satellite", emoji: "🛰️", label: "Redes", accent: "#39c5cf" },
  { id: "lock", emoji: "🔐", label: "Permisos", accent: "#ff7b72" },
  { id: "cloud", emoji: "☁️", label: "Cloud", accent: "#79c0ff" },
  { id: "shell", emoji: "🐚", label: "Shell", accent: "#7ee787" },
];

// Datos por ruta para calcular progreso en el cliente (sin backend).
const rutas = [...paths]
  .sort((a, b) => a.order - b.order)
  .map((p) => ({
    slug: p.slug,
    title: p.title,
    short: p.short,
    accent: p.accent,
    labIds: labs.filter((l) => l.data.path === p.slug).map((l) => l.id),
  }));

const totalLabs = labs.length;
const rutasData = JSON.stringify(rutas);
const avatarsData = JSON.stringify(avatarOptions);
const badgesData = JSON.stringify(
  badges.map((b) => ({ id: b.id, rule: b.rule })),
);
---

<BaseLayout
  title="Tu perfil"
  description="Tu progreso en Open Security Labs vive en tu navegador. Sin login, sin tracking. Llevátelo a otro dispositivo con un token portable."
  width="default"
>
  <section class="py-12">
    <p class="rule-label">Local · 0 login · 0 cookies</p>
    <h1 class="text-base-50 mt-3 text-3xl font-bold sm:text-4xl">Tu perfil</h1>
    <p class="text-base-300 mt-4 max-w-2xl text-lg leading-relaxed">
      Tu progreso se guarda <strong class="text-base-100"
        >solo en este navegador</strong
      >. No hay cuenta ni servidor. Si querés moverlo a otro equipo, exportá tu
      token y pegalo allá.
    </p>

    <div data-zero-state class="card mt-8 p-5">
      <p class="text-base-100 font-mono text-base font-semibold">
        Todavía no empezaste.
      </p>
      <p class="text-base-400 mt-2 max-w-2xl text-sm leading-relaxed">
        Hacé un lab corto, marcá la evidencia y recién ahí tu perfil empieza a
        tener sentido. Si ya tenés progreso en otro navegador, importá tu token.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href={firstLabHref} class="btn-primary text-xs">Hacer primer lab</a>
        <a href="/rutas" class="btn-ghost text-xs">Ver rutas</a>
        <button type="button" data-zero-import class="btn-ghost text-xs">
          Importar token
        </button>
      </div>
    </div>

    <!-- Identidad -->
    <div class="card mt-8 p-5">
      <div class="grid gap-5 sm:grid-cols-[auto_1fr] sm:items-start">
        <div
          data-avatar-preview
          class="border-base-700 bg-base-950/60 grid h-24 w-24 place-items-center rounded-2xl border text-5xl shadow-[0_18px_55px_rgba(0,0,0,0.24)]"
        >
          <span data-avatar-preview-emoji>🐧</span>
        </div>

        <div class="w-full">
          <label for="vtsl-username" class="rule-label mb-2 block"
            >Tu alias</label
          >
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-term-green font-mono text-sm">@</span>
            <input
              id="vtsl-username"
              type="text"
              maxlength="32"
              placeholder="elegí un alias…"
              data-username
              class="border-base-600 bg-base-850 text-base-50 placeholder:text-base-500 focus:border-term-green flex-1 rounded-md border px-3 py-2 font-mono text-sm outline-none"
            />
          </div>
          <p class="text-base-500 mt-2 font-mono text-xs">
            Solo cosmético. Aparece en tu tarjeta para compartir; no se envía a
            ningún lado.
          </p>
        </div>
      </div>

      <div class="mt-6">
        <p class="rule-label mb-3">Tu avatar</p>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4" data-avatar-options>
          {
            avatarOptions.map((avatar) => (
              <button
                type="button"
                data-avatar-option
                data-avatar-id={avatar.id}
                data-avatar-emoji={avatar.emoji}
                data-avatar-label={avatar.label}
                data-avatar-accent={avatar.accent}
                aria-pressed="false"
                class="border-base-700 bg-base-850/60 text-base-300 hover:border-term-green/50 hover:text-base-50 flex items-center gap-2 rounded-xl border px-3 py-2 text-left transition-colors"
              >
                <span
                  class="grid h-9 w-9 shrink-0 place-items-center rounded-lg text-xl"
                  style={`background: color-mix(in srgb, ${avatar.accent} 16%, transparent)`}
                  aria-hidden="true"
                >
                  {avatar.emoji}
                </span>
                <span class="font-mono text-xs">{avatar.label}</span>
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="card p-4">
        <p class="text-term-green font-mono text-3xl font-bold" data-stat-labs>
          0
        </p>
        <p class="text-base-400 mt-1 font-mono text-xs">
          / {totalLabs} labs hechos
        </p>
      </div>
      <div class="card p-4">
        <p class="text-term-cyan font-mono text-3xl font-bold" data-stat-rutas>
          0
        </p>
        <p class="text-base-400 mt-1 font-mono text-xs">
          / {rutas.length} rutas
        </p>
      </div>
      <div class="card p-4">
        <p class="text-term-amber font-mono text-3xl font-bold" data-stat-exams>
          0
        </p>
        <p class="text-base-400 mt-1 font-mono text-xs">exámenes pasados</p>
      </div>
      <div class="card p-4">
        <p class="text-term-violet font-mono text-3xl font-bold" data-stat-pct>
          0%
        </p>
        <p class="text-base-400 mt-1 font-mono text-xs">del catálogo</p>
      </div>
    </div>

    <!-- Insignias -->
    <div class="mt-10 flex items-baseline justify-between gap-3">
      <h2 class="rule-label">Insignias</h2>
      <span class="text-base-400 font-mono text-xs">
        <span class="text-term-green" data-badges-count>0</span>/{badges.length}
        ganadas
      </span>
    </div>
    <ul
      class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"
      data-badges-list
    >
      {badges.map((b) => <BadgeMedal badge={b} />)}
    </ul>

    <!-- Progreso por ruta -->
    <h2 class="rule-label mt-10 mb-3">Progreso por ruta</h2>
    <div class="space-y-3" data-rutas-list></div>

    <!-- Tarjeta para compartir -->
    <h2 class="rule-label mt-10 mb-3">Tu tarjeta</h2>
    <div
      data-card
      class="border-base-700 from-base-900 to-base-950 relative overflow-hidden rounded-xl border bg-gradient-to-br p-6"
    >
      <div
        class="bg-term-green/60 pointer-events-none absolute inset-x-0 top-0 h-px"
      >
      </div>
      <div class="text-center">
        <div
          data-card-avatar-tile
          class="border-base-700 bg-base-950/70 mx-auto grid h-20 w-20 place-items-center rounded-2xl border text-5xl"
        >
          <span data-card-avatar-emoji>🐧</span>
        </div>
        <p class="text-base-400 mt-4 font-mono text-xs">Open Security Labs</p>
        <p
          class="text-base-50 mx-auto mt-1 max-w-full truncate font-mono text-xl font-bold"
        >
          @<span data-card-user>anónimo</span>
        </p>
        <p
          class="text-term-green mt-4 font-mono text-5xl font-bold"
          data-card-pct
        >
          0%
        </p>
        <p class="text-base-400 font-mono text-xs">completado</p>
      </div>
      <div class="mt-5 flex justify-center gap-4 font-mono text-xs">
        <span class="text-base-300"
          ><span class="text-term-green" data-card-labs>0</span> labs</span
        >
        <span class="text-base-300"
          ><span class="text-term-cyan" data-card-rutas>0</span> rutas</span
        >
        <span class="text-base-300"
          ><span class="text-term-amber" data-card-exams>0</span> exámenes</span
        >
      </div>
      <p class="text-base-600 mt-4 font-mono text-[0.65rem]">
        securitylabs.valentorassa.com · aprendé haciendo, en abierto
      </p>
    </div>

    <div class="mt-3 flex flex-wrap gap-2">
      <button type="button" data-card-download class="btn-primary text-xs">
        ↓ Descargar imagen
      </button>
      <button type="button" data-card-copy class="btn-ghost text-xs">
        Copiar resumen
      </button>
    </div>

    <!-- Token portable -->
    <h2 class="rule-label mt-10 mb-3">Mover tu progreso</h2>
    <div class="card p-5">
      <p class="text-base-300 text-sm">
        Exportá un token con tu progreso y pegalo en otro navegador para
        recuperarlo. Es texto plano, sin datos personales.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" data-token-export class="btn-ghost text-xs">
          Generar mi token
        </button>
        <button type="button" data-token-import-btn class="btn-ghost text-xs">
          Importar un token
        </button>
      </div>
      <textarea
        rows="3"
        data-token-box
        placeholder="acá aparece tu token, o pegá uno para importar…"
        class="border-base-600 bg-base-850 text-base-200 placeholder:text-base-500 focus:border-term-green mt-3 w-full resize-y rounded-md border px-3 py-2 font-mono text-xs break-all outline-none"
      ></textarea>
      <p
        class="mt-2 hidden font-mono text-xs"
        data-token-msg
        aria-live="polite"
      >
      </p>
      <p class="text-base-500 mt-3 font-mono text-xs">
        ¿Empezás de cero?
        <button type="button" data-reset class="text-term-red hover:underline">
          Borrar todo mi progreso
        </button>
      </p>
    </div>
  </section>

  <script
    is:inline
    type="application/json"
    data-rutas-json
    set:html={rutasData}
  />
  <script
    is:inline
    type="application/json"
    data-avatars-json
    set:html={avatarsData}
  />
  <script
    is:inline
    type="application/json"
    data-badges-json
    set:html={badgesData}
  />
</BaseLayout>

<script>
  import {
    countDone,
    isExamPassed,
    onProgress,
    getUsername,
    setUsername,
    getAvatar,
    setAvatar,
    resetProfile,
    exportToken,
    importToken,
  } from "../scripts/progress";

  type Ruta = {
    slug: string;
    title: string;
    short: string;
    accent: string;
    labIds: string[];
  };

  // Tipo compartido con el server: si cambia la regla, TypeScript avisa acá.
  type BadgeRule = import("../data/badges").BadgeRule;
  type BadgeDef = { id: string; rule: BadgeRule };
  type AvatarOption = {
    id: string;
    emoji: string;
    label: string;
    accent: string;
  };

  const raw = document.querySelector<HTMLElement>("[data-rutas-json]");
  const rutas: Ruta[] = raw ? JSON.parse(raw.textContent ?? "[]") : [];
  const totalLabs = rutas.reduce((n, r) => n + r.labIds.length, 0);

  const badgesRaw = document.querySelector<HTMLElement>("[data-badges-json]");
  const badgeDefs: BadgeDef[] = badgesRaw
    ? JSON.parse(badgesRaw.textContent ?? "[]")
    : [];
  const avatarsRaw = document.querySelector<HTMLElement>("[data-avatars-json]");
  const avatars: AvatarOption[] = avatarsRaw
    ? JSON.parse(avatarsRaw.textContent ?? "[]")
    : [];

  const $ = <T extends HTMLElement>(s: string) => document.querySelector<T>(s);
  const zeroState = $<HTMLElement>("[data-zero-state]");

  const avatarButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-avatar-option]"),
  );
  const avatarPreview = $<HTMLElement>("[data-avatar-preview]");
  const avatarPreviewEmoji = $<HTMLElement>("[data-avatar-preview-emoji]");
  const cardAvatarTile = $<HTMLElement>("[data-card-avatar-tile]");
  const cardAvatarEmoji = $<HTMLElement>("[data-card-avatar-emoji]");

  const avatarById = (id: string) =>
    avatars.find((avatar) => avatar.id === id) ?? avatars[0];

  function paintAvatar() {
    const avatar = avatarById(getAvatar());
    if (!avatar) return;
    [avatarPreview, cardAvatarTile].forEach((el) => {
      if (!el) return;
      el.style.borderColor = `color-mix(in srgb, ${avatar.accent} 45%, transparent)`;
      el.style.background = `radial-gradient(circle at 30% 20%, color-mix(in srgb, ${avatar.accent} 24%, transparent), transparent 58%), color-mix(in srgb, ${avatar.accent} 9%, var(--color-base-950))`;
      el.style.boxShadow = `0 18px 55px color-mix(in srgb, ${avatar.accent} 18%, transparent)`;
    });
    if (avatarPreviewEmoji) avatarPreviewEmoji.textContent = avatar.emoji;
    if (cardAvatarEmoji) cardAvatarEmoji.textContent = avatar.emoji;
    avatarButtons.forEach((button) => {
      const selected = button.dataset.avatarId === avatar.id;
      button.setAttribute("aria-pressed", String(selected));
      button.dataset.selected = String(selected);
      button.style.borderColor = selected
        ? `color-mix(in srgb, ${avatar.accent} 60%, transparent)`
        : "";
      button.style.background = selected
        ? `color-mix(in srgb, ${avatar.accent} 12%, transparent)`
        : "";
      button.classList.toggle("text-base-50", selected);
      button.classList.toggle("text-base-300", !selected);
    });
  }

  avatarButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setAvatar(button.dataset.avatarId ?? "penguin");
      paintAvatar();
    });
  });

  // ---- Username ----
  const userInput = $<HTMLInputElement>("[data-username]");
  if (userInput) {
    userInput.value = getUsername();
    userInput.addEventListener("input", () => setUsername(userInput.value));
  }

  // ---- Lista de rutas ----
  const list = $<HTMLElement>("[data-rutas-list]");
  if (list) {
    rutas.forEach((r) => {
      const row = document.createElement("div");
      row.dataset.ruta = r.slug;
      row.style.setProperty("--accent", r.accent);
      row.className = "border-base-800 rounded-lg border p-3";
      row.innerHTML = `
        <div class="flex items-center justify-between font-mono text-xs">
          <a href="/rutas/${r.slug}" class="text-base-200 hover:text-[color:var(--accent)]">${r.title}</a>
          <span class="text-base-400" data-ruta-count>0/${r.labIds.length}</span>
        </div>
        <div class="bg-base-800 mt-2 h-1.5 w-full overflow-hidden rounded-full">
          <div class="h-full rounded-full transition-[width] duration-500" data-ruta-bar style="width:0%;background:var(--accent)"></div>
        </div>`;
      list.appendChild(row);
    });
  }

  // ---- Render de todo ----
  function render() {
    let labsDone = 0;
    let rutasDone = 0;
    let examsDone = 0;
    const completedRoutes = new Set<string>();

    rutas.forEach((r) => {
      const done = countDone(r.labIds);
      labsDone += done;
      if (r.labIds.length > 0 && done === r.labIds.length) {
        rutasDone += 1;
        completedRoutes.add(r.slug);
      }
      if (isExamPassed(`ruta:${r.slug}`)) examsDone += 1;

      const row = document.querySelector<HTMLElement>(
        `[data-ruta="${r.slug}"]`,
      );
      if (row) {
        const pct = r.labIds.length
          ? Math.round((done / r.labIds.length) * 100)
          : 0;
        const bar = row.querySelector<HTMLElement>("[data-ruta-bar]");
        const count = row.querySelector<HTMLElement>("[data-ruta-count]");
        if (bar) bar.style.width = `${pct}%`;
        if (count) count.textContent = `${done}/${r.labIds.length}`;
      }
    });

    const pct = totalLabs ? Math.round((labsDone / totalLabs) * 100) : 0;

    const setText = (sel: string, val: string) => {
      const el = $<HTMLElement>(sel);
      if (el) el.textContent = val;
    };
    setText("[data-stat-labs]", String(labsDone));
    setText("[data-stat-rutas]", String(rutasDone));
    setText("[data-stat-exams]", String(examsDone));
    setText("[data-stat-pct]", `${pct}%`);

    setText("[data-card-user]", getUsername() || "anónimo");
    paintAvatar();
    setText("[data-card-pct]", `${pct}%`);
    setText("[data-card-labs]", String(labsDone));
    setText("[data-card-rutas]", String(rutasDone));
    setText("[data-card-exams]", String(examsDone));

    // ---- Insignias ----
    const earned = (rule: BadgeRule): boolean => {
      switch (rule.kind) {
        case "labs":
          return labsDone >= rule.n;
        case "rutas":
          return rutasDone >= rule.n;
        case "exams":
          return examsDone >= rule.n;
        case "allLabs":
          return totalLabs > 0 && labsDone >= totalLabs;
        case "route":
          return completedRoutes.has(rule.route);
      }
    };
    let badgesDone = 0;
    badgeDefs.forEach((b) => {
      const got = earned(b.rule);
      if (got) badgesDone += 1;
      const el = document.querySelector<HTMLElement>(`[data-badge="${b.id}"]`);
      if (el) el.dataset.earned = got ? "true" : "false";
    });
    setText("[data-badges-count]", String(badgesDone));
    zeroState?.classList.toggle("hidden", labsDone > 0);

    return { labsDone, rutasDone, examsDone, pct };
  }

  render();
  onProgress(render);

  // ---- Token export / import ----
  const box = $<HTMLTextAreaElement>("[data-token-box]");
  const msg = $<HTMLElement>("[data-token-msg]");
  const showMsg = (text: string, ok: boolean) => {
    if (!msg) return;
    msg.textContent = text;
    msg.className = `mt-2 font-mono text-xs ${ok ? "text-term-green" : "text-term-red"}`;
    msg.classList.remove("hidden");
  };

  $<HTMLButtonElement>("[data-token-export]")?.addEventListener("click", () => {
    if (box) box.value = exportToken();
    showMsg("✓ Token generado. Copialo y guardalo donde quieras.", true);
  });

  $<HTMLButtonElement>("[data-token-import-btn]")?.addEventListener(
    "click",
    () => {
      const token = box?.value ?? "";
      if (!token.trim()) {
        showMsg("Pegá un token en el cuadro antes de importar.", false);
        return;
      }
      if (importToken(token)) {
        showMsg("✓ Progreso importado y fusionado.", true);
        if (userInput) userInput.value = getUsername();
        paintAvatar();
        render();
      } else {
        showMsg("✕ Token inválido. ¿Lo copiaste completo?", false);
      }
    },
  );

  $<HTMLButtonElement>("[data-zero-import]")?.addEventListener("click", () => {
    box?.focus();
    box?.scrollIntoView({ behavior: "smooth", block: "center" });
  });

  // ---- Reset ----
  $<HTMLButtonElement>("[data-reset]")?.addEventListener("click", () => {
    if (!confirm("¿Seguro? Esto borra tu progreso de este navegador.")) return;
    rutas.forEach((r) => {
      r.labIds.forEach((id) => localStorage.removeItem(`vtsl:done:${id}`));
      localStorage.removeItem(`vtsl:exam:ruta:${r.slug}`);
    });
    resetProfile();
    if (userInput) userInput.value = "";
    if (box) box.value = "";
    paintAvatar();
    window.dispatchEvent(new CustomEvent("vtsl:progress"));
    showMsg("Progreso borrado.", true);
  });

  // ---- Copiar resumen ----
  $<HTMLButtonElement>("[data-card-copy]")?.addEventListener(
    "click",
    async () => {
      const s = render();
      const user = getUsername() || "anónimo";
      const avatar = avatarById(getAvatar());
      const text = `${avatar?.emoji ?? "🐧"} @${user} en Open Security Labs: ${s.pct}% del catálogo · ${s.labsDone} labs · ${s.rutasDone} rutas · ${s.examsDone} exámenes. securitylabs.valentorassa.com`;
      try {
        await navigator.clipboard.writeText(text);
        showMsg("✓ Resumen copiado al portapapeles.", true);
      } catch {
        showMsg("No pude copiar; copiá el token a mano.", false);
      }
    },
  );

  // ---- Descargar tarjeta como PNG (canvas, sin librerías) ----
  $<HTMLButtonElement>("[data-card-download]")?.addEventListener(
    "click",
    () => {
      const s = render();
      const user = getUsername() || "anónimo";
      const avatar = avatarById(getAvatar());
      const W = 1200;
      const H = 630;
      const canvas = document.createElement("canvas");
      canvas.width = W;
      canvas.height = H;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const grad = ctx.createLinearGradient(0, 0, W, H);
      grad.addColorStop(0, "#0b0f11");
      grad.addColorStop(1, "#07090a");
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      ctx.fillStyle = "#56d364";
      ctx.fillRect(0, 0, W, 6);

      const mono = "'JetBrains Mono Variable', ui-monospace, monospace";
      ctx.textAlign = "center";

      ctx.fillStyle = "#5a6b75";
      ctx.font = `28px ${mono}`;
      ctx.fillText("Open Security Labs", W / 2, 78);

      if (avatar) {
        const avatarGrad = ctx.createRadialGradient(
          W / 2,
          188,
          8,
          W / 2,
          188,
          82,
        );
        avatarGrad.addColorStop(0, avatar.accent);
        avatarGrad.addColorStop(1, "#101820");
        ctx.fillStyle = avatarGrad;
        ctx.beginPath();
        ctx.roundRect(W / 2 - 88, 100, 176, 176, 32);
        ctx.fill();
        ctx.strokeStyle = avatar.accent;
        ctx.lineWidth = 3;
        ctx.stroke();
        ctx.font = `96px ${mono}`;
        ctx.textBaseline = "middle";
        ctx.fillText(avatar.emoji, W / 2, 190);
        ctx.textBaseline = "alphabetic";
      }

      ctx.fillStyle = "#f1f5f6";
      ctx.font = `bold 72px ${mono}`;
      ctx.fillText(`@${user}`, W / 2, 360);

      ctx.fillStyle = "#56d364";
      ctx.font = `bold 160px ${mono}`;
      ctx.fillText(`${s.pct}%`, W / 2, 505);
      ctx.fillStyle = "#5a6b75";
      ctx.font = `32px ${mono}`;
      ctx.fillText("del catálogo completado", W / 2, 550);

      ctx.font = `36px ${mono}`;
      const line = [
        ["#56d364", `${s.labsDone} labs`],
        ["#39c5cf", `${s.rutasDone} rutas`],
        ["#e3b341", `${s.examsDone} exámenes`],
      ] as const;
      const gap = 50;
      const totalWidth = line.reduce(
        (width, [, label], idx) =>
          width + ctx.measureText(label).width + (idx > 0 ? gap : 0),
        0,
      );
      let x = W / 2 - totalWidth / 2;
      ctx.textAlign = "left";
      line.forEach(([color, label]) => {
        ctx.fillStyle = color as string;
        ctx.fillText(label, x, 590);
        x += ctx.measureText(label).width + 50;
      });

      ctx.fillStyle = "#3b4750";
      ctx.font = `22px ${mono}`;
      ctx.textAlign = "center";
      ctx.fillText("securitylabs.valentorassa.com", W / 2, 620);

      const url = canvas.toDataURL("image/png");
      const a = document.createElement("a");
      a.href = url;
      a.download = `vtsl-${user}.png`;
      a.click();
    },
  );
</script>
