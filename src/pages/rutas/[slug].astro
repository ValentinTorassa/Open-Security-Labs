---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LabCard from "../../components/LabCard.astro";
import Exam from "../../components/Exam.astro";
import { paths } from "../../data/paths";
import { pathExams } from "../../data/path-exams";
import { sortLabs } from "../../data/labs";
import { SITE_URL } from "../../data/site";

export const getStaticPaths = (async () => {
  return paths.map((path) => ({
    params: { slug: path.slug },
    props: { path },
  }));
}) satisfies GetStaticPaths;

const { path } = Astro.props;
const exam = pathExams[path.slug];

// Navegación entre rutas (orden de paths.ts).
const ordered = [...paths].sort((a, b) => a.order - b.order);
const idx = ordered.findIndex((p) => p.slug === path.slug);
const prevPath = idx > 0 ? ordered[idx - 1] : undefined;
const nextPath = idx < ordered.length - 1 ? ordered[idx + 1] : undefined;

const allLabs = await getCollection("labs", ({ data }) => !data.draft);
const labs = sortLabs(allLabs.filter((l) => l.data.path === path.slug));

const examStoreKey = `ruta:${path.slug}`;
const firstLab = labs[0];
const site = Astro.site ?? new URL(SITE_URL);
const routeUrl = new URL(`/rutas/${path.slug}/`, site).href;
const routeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: path.title,
    url: routeUrl,
    description: path.positioning,
    inLanguage: "es-AR",
    numberOfItems: labs.length,
    about: path.focus,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Rutas",
        item: new URL("/rutas/", site).href,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: path.title,
        item: routeUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={path.title}
  description={path.positioning}
  width="wide"
  jsonLd={routeJsonLd}
>
  <section class="py-12" style={`--accent: ${path.accent}`}>
    <nav class="text-base-400 mb-6 font-mono text-xs" aria-label="Migas de pan">
      <a href="/rutas/" class="hover:text-term-green">rutas</a>
      <span class="text-base-500 mx-1.5" aria-hidden="true">/</span>
      <span class="accent-text">{path.slug}</span>
    </nav>

    <div class="flex flex-wrap items-center gap-3">
      <span
        class="flex h-11 w-11 items-center justify-center rounded-lg border font-mono text-lg font-bold"
        style="border-color: color-mix(in srgb, var(--accent) 40%, transparent); color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent)"
      >
        {String(path.order).padStart(2, "0")}
      </span>
      <h1 class="text-base-50 text-3xl font-bold sm:text-4xl">{path.title}</h1>
      <span
        data-ruta-complete-badge
        class="border-term-green/40 bg-term-green/10 text-term-green glow-green hidden items-center gap-1.5 rounded-full border px-3 py-1 font-mono text-xs font-semibold"
      >
        ✓ Ruta completada
      </span>
    </div>

    <p class="text-base-200 mt-4 max-w-2xl text-lg leading-relaxed">
      {path.positioning}
    </p>

    {
      firstLab && (
        <a
          href={`/labs/${firstLab.id}/`}
          data-ruta-start
          class="btn-primary mt-6 inline-flex"
        >
          <span data-ruta-start-label>Empezar esta ruta</span>
          <span aria-hidden="true">→</span>
        </a>
      )
    }

    <!-- Temario -->
    <div class="mt-8">
      <h2 class="rule-label mb-3">Qué cubre esta ruta</h2>
      <div class="flex flex-wrap gap-2">
        {
          path.focus.map((f) => (
            <span class="border-base-700 bg-base-850/60 text-base-300 rounded-md border px-2.5 py-1 font-mono text-xs">
              {f}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Labs -->
    <div class="mt-12">
      <div class="mb-5 flex items-baseline justify-between">
        <h2 class="text-base-50 text-xl font-semibold">Labs de la ruta</h2>
        <span class="text-base-400 font-mono text-xs">
          {labs.length}{" "}
          {labs.length === 1 ? "lab" : "labs"}
        </span>
      </div>

      <div data-ruta-progress-wrap class="mb-5 hidden">
        <div class="bg-base-800 h-1.5 w-full overflow-hidden rounded-full">
          <div
            data-ruta-progress-bar
            class="h-full rounded-full transition-[width] duration-500"
            style="width: 0%; background: var(--accent)"
            role="progressbar"
            aria-label={`Progreso en ${path.title}`}
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
          >
          </div>
        </div>
        <p
          data-ruta-progress-label
          class="text-base-400 mt-2 font-mono text-xs"
        >
        </p>
      </div>

      {
        labs.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2">
            {labs.map((lab) => (
              <LabCard lab={lab} showPath={false} />
            ))}
          </div>
        ) : (
          <div class="border-base-700 bg-base-850/40 rounded-xl border border-dashed p-8 text-center">
            <p class="text-base-400 font-mono text-sm">
              Todavía no hay labs publicados en esta ruta.
            </p>
            <a
              href="/contribuir/"
              class="text-term-green mt-3 inline-block text-sm hover:underline"
            >
              ¿Querés escribir el primero? →
            </a>
          </div>
        )
      }
    </div>

    <!-- Examen corto de la ruta: se desbloquea al completar los labs -->
    {
      exam && exam.length > 0 && (
        <div class="mt-14" data-exam-gate>
          <h2 class="rule-label mb-1">Cerrá la ruta</h2>
          <p class="text-base-300 mb-4 text-sm">
            Un examen corto para ver si te quedaron los conceptos clave.
          </p>

          <div
            data-exam-locked
            class="border-base-700 bg-base-850/40 rounded-xl border border-dashed p-7 text-center"
          >
            <p class="text-base-200 text-sm">
              <span aria-hidden="true">🔒</span> Completá los {labs.length} labs
              de la ruta para desbloquear el examen.
            </p>
            <div class="bg-base-800 mx-auto mt-4 h-1.5 max-w-xs overflow-hidden rounded-full">
              <div
                data-exam-gate-bar
                class="h-full rounded-full transition-[width] duration-500"
                style="width: 0%; background: var(--accent)"
                role="progressbar"
                aria-label="Progreso para desbloquear el examen"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
              />
            </div>
            <p
              data-exam-gate-label
              class="text-base-500 mt-2 font-mono text-xs"
            >
              0/{labs.length} labs
            </p>
          </div>

          <div data-exam-content class="hidden">
            <Exam
              questions={exam}
              passScore={67}
              title={`Examen: ${path.title}`}
              storeKey={examStoreKey}
            />
          </div>
        </div>
      )
    }

    <nav
      class="border-base-800 mt-14 grid gap-3 border-t pt-6 sm:grid-cols-2"
      aria-label="Navegación entre rutas"
    >
      {
        prevPath ? (
          <a
            href={`/rutas/${prevPath.slug}/`}
            class="card group flex flex-col p-4 hover:-translate-y-0.5"
            style={`--accent: ${prevPath.accent}`}
          >
            <span class="text-base-500 font-mono text-xs">← Ruta anterior</span>
            <span class="text-base-100 mt-1 font-semibold group-hover:text-[color:var(--accent)]">
              {prevPath.title}
            </span>
          </a>
        ) : (
          <span />
        )
      }
      {
        nextPath && (
          <a
            href={`/rutas/${nextPath.slug}/`}
            class="card group flex flex-col p-4 text-right hover:-translate-y-0.5 sm:col-start-2"
            style={`--accent: ${nextPath.accent}`}
          >
            <span class="text-base-500 font-mono text-xs">
              Ruta siguiente →
            </span>
            <span class="text-base-100 mt-1 font-semibold group-hover:text-[color:var(--accent)]">
              {nextPath.title}
            </span>
          </a>
        )
      }
    </nav>

    <div class="mt-10">
      <a
        href="/rutas/"
        class="text-base-400 hover:text-term-green font-mono text-sm"
      >
        ← Volver a todas las rutas
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  import { isLabDone, onProgress } from "../../scripts/progress";

  const cards = Array.from(
    document.querySelectorAll<HTMLElement>("[data-lab-card]"),
  );
  const total = cards.length;

  const wrap = document.querySelector("[data-ruta-progress-wrap]");
  const bar = document.querySelector<HTMLElement>("[data-ruta-progress-bar]");
  const label = document.querySelector("[data-ruta-progress-label]");
  const completeBadge = document.querySelector("[data-ruta-complete-badge]");
  const gate = document.querySelector("[data-exam-gate]");
  const start = document.querySelector<HTMLAnchorElement>("[data-ruta-start]");
  const startLabel = document.querySelector<HTMLElement>(
    "[data-ruta-start-label]",
  );

  function render() {
    if (!total) return;
    let done = 0;
    let nextHref = "";
    cards.forEach((card) => {
      const id = card.dataset.labId ?? "";
      const ok = isLabDone(id);
      if (ok) done += 1;
      else if (!nextHref) nextHref = (card as HTMLAnchorElement).href;
      const badge = card.querySelector("[data-done-badge]");
      badge?.classList.toggle("hidden", !ok);
      badge?.classList.toggle("inline-flex", ok);
    });

    const pct = Math.round((done / total) * 100);
    const allDone = done === total;

    wrap?.classList.toggle("hidden", done === 0);
    if (bar) {
      bar.style.width = `${pct}%`;
      bar.setAttribute("aria-valuenow", String(pct));
    }
    if (label)
      label.textContent = `${done}/${total} labs completados · ${pct}%`;

    completeBadge?.classList.toggle("hidden", !allDone);
    completeBadge?.classList.toggle("inline-flex", allDone);

    if (start && startLabel) {
      if (nextHref) {
        start.href = nextHref;
        startLabel.textContent =
          done > 0 ? "Continuar esta ruta" : "Empezar esta ruta";
      } else {
        startLabel.textContent = "Repasar esta ruta";
      }
    }

    if (gate) {
      const gbar = gate.querySelector<HTMLElement>("[data-exam-gate-bar]");
      const glabel = gate.querySelector("[data-exam-gate-label]");
      if (gbar) {
        gbar.style.width = `${pct}%`;
        gbar.setAttribute("aria-valuenow", String(pct));
      }
      if (glabel) glabel.textContent = `${done}/${total} labs`;
      gate
        .querySelector("[data-exam-locked]")
        ?.classList.toggle("hidden", allDone);
      gate
        .querySelector("[data-exam-content]")
        ?.classList.toggle("hidden", !allDone);
    }
  }

  render();
  onProgress(render);
</script>
