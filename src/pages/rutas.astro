---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PathCard from "../components/PathCard.astro";
import { paths } from "../data/paths";
import { sortLabs } from "../data/labs";
import { SITE_URL } from "../data/site";

const labs = sortLabs(await getCollection("labs", ({ data }) => !data.draft));
const labsFor = (slug: string) => labs.filter((l) => l.data.path === slug);
const firstLab = labs.find((l) => l.data.level === "beginner");
const firstLabHref = firstLab ? `/labs/${firstLab.id}/` : "/labs/";

const quickStarts = [
  {
    label: "Vengo de cero",
    href: firstLabHref,
    body: "Hacé un primer lab corto y conseguí evidencia rápido.",
  },
  {
    label: "Soy dev/backend",
    href: "/rutas/backend-arquitectura/",
    body: "Arrancá por APIs, permisos, sesiones y modos de falla.",
  },
  {
    label: "Quiero cloud/security",
    href: "/rutas/cloud-produccion/",
    body: "Seguí por IAM, logs, redes cloud y blast radius.",
  },
];

const site = Astro.site ?? new URL(SITE_URL);
const rutasJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Rutas de aprendizaje",
  url: new URL("/rutas/", site).href,
  inLanguage: "es-AR",
  numberOfItems: paths.length,
  about: paths.map((path) => path.title),
};
---

<BaseLayout
  title="Rutas de aprendizaje"
  description="Seis rutas para entender los sistemas de verdad: Linux, redes, backend, cloud, ciberseguridad y DevSecOps con agentes."
  width="wide"
  jsonLd={rutasJsonLd}
>
  <section class="py-12">
    <p class="rule-label">Rutas de aprendizaje</p>
    <h1 class="text-base-50 mt-3 max-w-3xl text-3xl font-bold sm:text-4xl">
      Seis rutas, una idea: entender el sistema antes de defenderlo.
    </h1>
    <p class="text-base-300 mt-4 max-w-2xl text-lg leading-relaxed">
      Cada ruta arranca desde abajo, con labs prácticos que corrés en tu
      máquina. Empezá por la que te sirva hoy. Es open source: si algo falta o
      está mal, lo podés mejorar vos.
    </p>

    <div class="mt-8 grid gap-3 md:grid-cols-3">
      {
        quickStarts.map((item) => (
          <a href={item.href} class="card group p-4 hover:-translate-y-0.5">
            <span class="text-base-100 group-hover:text-term-green block font-mono text-sm font-semibold">
              {item.label}
            </span>
            <span class="text-base-400 mt-1 block text-sm leading-relaxed">
              {item.body}
            </span>
          </a>
        ))
      }
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        paths.map((path) => {
          const pathLabs = labsFor(path.slug);
          return (
            <PathCard
              path={path}
              labCount={pathLabs.length}
              labIds={pathLabs.map((l) => l.id)}
            />
          );
        })
      }
    </div>
  </section>
</BaseLayout>
