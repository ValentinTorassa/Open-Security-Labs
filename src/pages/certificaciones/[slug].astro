---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Exam from "../../components/Exam.astro";
import Icon from "../../components/Icon.astro";
import CredentialBadge from "../../components/CredentialBadge.astro";
import { certifications } from "../../data/certifications";
import { getPath } from "../../data/paths";

export const getStaticPaths = (async () => {
  return certifications.map((cert) => ({
    params: { slug: cert.slug },
    props: { cert },
  }));
}) satisfies GetStaticPaths;

const { cert } = Astro.props;
const relatedPaths = cert.relatedPaths
  .map((slug) => getPath(slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const labs = await getCollection("labs", ({ data }) => !data.draft);

const examFacts = [
  {
    icon: "list-checks" as const,
    label: "Preguntas",
    value: `${cert.meta.questions}`,
  },
  {
    icon: "clock" as const,
    label: "Duración",
    value: `${cert.meta.durationMin} min`,
  },
  {
    icon: "gauge" as const,
    label: "Aprobás con",
    value: cert.meta.passingScore,
  },
  { icon: "banknote" as const, label: "Costo aprox.", value: cert.meta.cost },
  {
    icon: "calendar" as const,
    label: "Validez",
    value: `${cert.meta.validityYears} años`,
  },
  { icon: "file-text" as const, label: "Formato", value: cert.meta.format },
];

const domainsWithLabs = cert.domains.map((d) => {
  const mappedLabs = cert.domainLabs.find((m) => m.domainName === d.name);
  const domainLabsList = mappedLabs
    ? mappedLabs.labIds
        .map((id) => labs.find((l) => l.id === id))
        .filter((l): l is NonNullable<typeof l> => Boolean(l))
    : [];
  return {
    ...d,
    labsList: domainLabsList,
  };
});
---

<BaseLayout title={cert.name} description={cert.summary} width="default">
  <article class="py-12" style={`--accent: ${cert.accent}`}>
    <nav class="text-base-400 mb-6 font-mono text-xs" aria-label="Migas de pan">
      <a href="/certificaciones" class="hover:text-term-green"
        >certificaciones</a
      >
      <span class="text-base-600 mx-1.5">/</span>
      <span style="color: var(--accent)">{cert.slug}</span>
    </nav>

    <!-- Header -->
    <header
      class="border-base-800 flex flex-wrap items-start gap-4 border-b pb-8"
    >
      {
        cert.badgeImage ? (
          <span
            class="border-base-800 bg-base-950 flex h-24 w-24 shrink-0 items-center justify-center overflow-hidden rounded-3xl border p-3 shadow-[0_22px_55px_rgba(0,0,0,0.25)] ring-1 ring-white/10 sm:h-28 sm:w-28"
            aria-hidden="true"
          >
            <img
              src={cert.badgeImage}
              alt=""
              width="112"
              height="112"
              decoding="async"
              class="h-full w-full object-contain"
            />
          </span>
        ) : (
          <CredentialBadge icon={cert.icon} accent={cert.accent} size={64} />
        )
      }
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-2 font-mono text-xs">
          <span
            class="rounded border px-2 py-0.5"
            style="border-color: color-mix(in srgb, var(--accent) 35%, transparent); color: var(--accent)"
          >
            {cert.code}
          </span>
          <span
            class="border-base-700 text-base-400 rounded border px-2 py-0.5"
          >
            {cert.level}
          </span>
          <span class="text-base-400">· {cert.vendor}</span>
        </div>
        <h1 class="text-base-50 mt-3 text-3xl font-bold sm:text-4xl">
          {cert.name}
        </h1>
        <p class="text-base-300 mt-3 text-lg leading-relaxed">{cert.summary}</p>
      </div>
    </header>

    <!-- Datos del examen -->
    <section class="mt-10">
      <h2 class="text-base-50 text-xl font-semibold">Datos del examen</h2>
      <p class="text-base-400 mt-1 text-sm">
        Valores aproximados. Confirmá siempre en la guía oficial vigente.
      </p>
      <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3">
        {
          examFacts.map((f) => (
            <div class="border-base-800 bg-base-850/30 rounded-lg border p-4">
              <span
                class="flex items-center gap-2 font-mono text-xs"
                style="color: var(--accent)"
              >
                <Icon name={f.icon} size={15} />
                {f.label}
              </span>
              <p class="text-base-100 mt-2 text-sm font-semibold">{f.value}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Recursos de estudio recomendados (PROTAGONISMO) -->
    <section class="mt-12">
      <h2 class="text-base-50 flex items-center gap-2 text-xl font-semibold">
        <Icon name="book" size={20} class="text-term-green" />
        Recursos recomendados
      </h2>
      <p class="text-base-400 mt-1 text-sm">
        Materiales seleccionados y gratuitos de alta calidad para dominar la
        teoría.
      </p>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        {
          cert.studyResources.map((res) => (
            <a
              href={res.url}
              target="_blank"
              rel="noopener noreferrer"
              class="border-base-800 bg-base-850/30 group relative flex flex-col justify-between rounded-xl border p-5 transition-colors hover:border-[color:var(--accent)]"
              style={`--accent: ${cert.accent}`}
            >
              <div>
                <div class="flex items-center justify-between gap-2">
                  <span class="text-base-500 font-mono text-[0.68rem] tracking-[0.12em] uppercase">
                    {res.platform} · {res.type}
                  </span>
                  <span class="bg-term-green/10 text-term-green rounded-full px-2 py-0.5 font-mono text-[0.65rem] font-bold">
                    {res.free ? "Gratis" : "De pago"}
                  </span>
                </div>
                <h3 class="text-base-100 mt-2.5 font-mono text-sm font-semibold transition-colors group-hover:text-[color:var(--accent)]">
                  {res.name}
                </h3>
                <p class="text-base-400 mt-2 text-xs leading-relaxed">
                  {res.desc}
                </p>
              </div>
              <div class="text-base-400 mt-4 flex items-center font-mono text-[0.7rem] transition-colors group-hover:text-[color:var(--accent)]">
                <span>Acceder al recurso</span>
                <span class="ml-1 transition-transform group-hover:translate-x-0.5">
                  →
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Tips de preparación -->
    <section class="border-base-800 bg-base-900/40 mt-12 rounded-xl border p-5">
      <h3
        class="text-base-100 flex items-center gap-2 font-mono text-sm font-semibold"
      >
        <Icon name="lightbulb" size={17} class="text-[color:var(--accent)]" />
        Consejos estratégicos para el examen
      </h3>
      <ul class="mt-3.5 space-y-2.5">
        {
          cert.prepTips.map((tip) => (
            <li class="text-base-300 flex items-start gap-2.5 text-xs leading-relaxed">
              <span class="text-base-500 mt-0.5 font-mono select-none">▪</span>
              <span>{tip}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Qué vas a poder hacer -->
    <section class="mt-12">
      <h2 class="text-base-50 text-xl font-semibold">Qué vas a poder hacer</h2>
      <p class="text-base-400 mt-1 text-sm">
        Lo que valida la certificación una vez que la tenés.
      </p>
      <ul class="mt-4 grid gap-2.5 sm:grid-cols-2">
        {
          cert.outcomes.map((o) => (
            <li class="text-base-200 flex items-start gap-2.5 text-sm">
              <span class="mt-0.5 shrink-0" style="color: var(--accent)">
                <Icon name="check" size={16} />
              </span>
              {o}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Dominios con Mapeo a Labs -->
    <section class="mt-12">
      <h2 class="text-base-50 text-xl font-semibold">Dominios del examen</h2>
      <p class="text-base-400 mt-1 text-sm">
        Cada área ponderada. Completá los labs sugeridos para dominar cada
        dominio práctico.
      </p>
      <ul class="mt-5 space-y-6">
        {
          domainsWithLabs.map((d) => (
            <li class="border-base-800/40 bg-base-900/10 rounded-xl border p-4 sm:p-5">
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-base-100 text-sm font-semibold">
                  {d.name}
                </span>
                <span class="text-base-400 font-mono text-xs">{d.weight}%</span>
              </div>
              <div class="bg-base-850 mt-2 h-1.5 w-full overflow-hidden rounded-full">
                <div
                  class="h-full rounded-full"
                  style={`width: ${d.weight}%; background-color: var(--accent);`}
                />
              </div>

              {d.labsList.length > 0 && (
                <div class="mt-4">
                  <span class="text-base-500 mb-2 block font-mono text-[0.65rem] tracking-wider uppercase">
                    Labs prácticos recomendados:
                  </span>
                  <div class="flex flex-wrap gap-2">
                    {d.labsList.map((lab) => (
                      <a
                        href={`/labs/${lab.id}`}
                        class="bg-base-850 hover:bg-base-800 border-base-750 text-base-300 hover:text-base-50 inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 font-mono text-xs transition-colors"
                      >
                        <span class="text-term-green" aria-hidden="true">
                          &gt;_
                        </span>
                        {lab.data.title}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Rutas que preparan -->
    {
      relatedPaths.length > 0 && (
        <section class="mt-12">
          <h2 class="text-base-50 text-xl font-semibold">
            Rutas de estudio sugeridas
          </h2>
          <p class="text-base-400 mt-1 text-sm">
            Caminos guiados para organizar tu preparación global.
          </p>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedPaths.map((p) => (
              <a
                href={`/rutas/${p.slug}`}
                class="card group flex items-center gap-3 p-4 hover:-translate-y-0.5"
                style={`--accent: ${p.accent}`}
              >
                <span
                  class="flex h-9 w-9 items-center justify-center rounded-md border"
                  style="border-color: color-mix(in srgb, var(--accent) 40%, transparent); color: var(--accent)"
                >
                  <Icon name={p.icon} size={18} />
                </span>
                <span class="flex-1">
                  <span class="text-base-50 block text-sm font-medium group-hover:text-[color:var(--accent)]">
                    {p.title}
                  </span>
                  <span class="text-base-400 block font-mono text-xs">
                    {p.tagline}
                  </span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- Examen de práctica -->
    <section class="mt-14">
      <h2 class="text-base-50 text-xl font-semibold">Examen de práctica</h2>
      <p class="text-base-400 mt-1 text-sm">
        Respondé las preguntas simuladas y evaluá tu nivel. Cada respuesta tiene
        feedback inmediato.
      </p>
      <Exam
        questions={cert.exam}
        passScore={70}
        title={`Práctica · ${cert.code}`}
        subtitle="Preguntas propias de práctica, no del examen real."
      />
    </section>

    <p class="text-base-500 mt-8 font-mono text-xs leading-relaxed">
      Open Security Labs no está afiliado a {cert.vendor}. {cert.name} y su código
      son marcas de su dueño. Verificá siempre los dominios vigentes en la guía oficial
      del examen antes de rendir.
    </p>
  </article>
</BaseLayout>
